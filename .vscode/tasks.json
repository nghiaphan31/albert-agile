{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start services (LiteLLM + Presidio + SearXNG)",
      "type": "shell",
      "command": "./scripts/start_services.sh",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {}
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": ".",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[start_services\\]",
          "endsPattern": "."
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
