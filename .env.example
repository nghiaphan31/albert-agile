# Copier vers .env et remplir les valeurs. Ne jamais commiter .env
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://eu.api.smith.langchain.com
LANGCHAIN_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# Cascade Coût Zéro (spec §5.1b) — litellm_config.yaml
# GEMINI_FREE_KEY : clé Google AI Studio (gratuit). Si une seule clé : GEMINI_FREE_KEY=$GOOGLE_API_KEY
GEMINI_FREE_KEY=
GEMINI_PAYANT_KEY=
VERTEX_PROJECT=
DEEPSEEK_API_KEY=

# Presidio (spec §10.1) — PII masking LiteLLM. Requis si presidio dans callbacks.
PRESIDIO_ANALYZER_API_BASE=http://localhost:5002
PRESIDIO_ANONYMIZER_API_BASE=http://localhost:5001

# SearXNG (spec §9) — recherche web pour agents (search_web tool)
SEARXNG_BASE_URL=http://localhost:8080

# Sandboxing (spec §7.1) — exécuter pytest dans un conteneur Docker. Build: docker compose build sandbox
AGILE_SANDBOX_RUN_SHELL=
